{
  "multipart": [
    {
      "when": { "axis": "y" },
      "apply": {
        "model": "terracompositio:block/flow_cedar_casing"
      }
    },
    {
      "when": { "axis": "y", "infused": true },
      "apply": {
        "model": "terracompositio:block/flow_cedar_casing_infused"
      }
    },
    {
      "when": { "axis": "x" },
      "apply": {
        "model": "terracompositio:block/flow_cedar_casing_horizontal",
        "x": 90,
        "y": 90
      }
    },
    {
      "when": { "axis": "z" },
      "apply": {
        "model": "terracompositio:block/flow_cedar_casing_horizontal",
        "x": 90
      }
    },
    {
      "when": { "axis": "x", "infused": true },
      "apply": {
        "model": "terracompositio:block/flow_cedar_casing_horizontal_infused",
        "x": 90,
        "y": 90
      }
    },
    {
      "when": { "axis": "z", "infused": true },
      "apply": {
        "model": "terracompositio:block/flow_cedar_casing_horizontal_infused",
        "x": 90
      }
    }
  ]
}